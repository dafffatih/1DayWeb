ng-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive h-9 px-4 py-2 has-[&gt;svg]:px-3 rounded-full bg-white text-black hover:bg-gray-200\" href=\"#packages\">Start Project</a></div></div></header><div class=\"flex-1\"><main class=\"min-h-screen bg-black text-white\"><section class=\"relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-black text-white px-4\"><div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-600/20 rounded-full blur-[120px] pointer-events-none\"></div><div class=\"absolute top-0 right-0 w-[400px] h-[400px] bg-purple-600/20 rounded-full blur-[100px] pointer-events-none\"></div><div class=\"relative z-10 max-w-5xl mx-auto text-center\"><div class=\"inline-flex items-center gap-2 px-3 py-1.5 mb-6 rounded-full bg-white/5 border border-white/10 text-sm font-medium\" style=\"opacity:0;filter:blur(10px);transform:scale(0.95)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-zap w-4 h-4 text-yellow-400\" aria-hidden=\"true\"><path d=\"M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z\"></path></svg><span>Stop waiting months for an agency</span></div><h1 class=\"text-5xl md:text-7xl font-extrabold tracking-tight mb-8\" style=\"opacity:0;transform:translateY(20px)\">Build your website in <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500\">one day.</span></h1><p class=\"text-xl md:text-2xl text-gray-400 max-w-3xl mx-auto mb-10 leading-relaxed\" style=\"opacity:0;transform:translateY(20px)\">A premium, fully-functional web presence designed, developed, and delivered before you even finish your morning coffee tomorrow.</p><div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\" style=\"opacity:0;transform:translateY(20px)\"><a data-slot=\"button\" data-variant=\"default\" data-size=\"lg\" class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-all disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg:not([class*=&#x27;size-&#x27;])]:size-4 shrink-0 [&amp;_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive has-[&gt;svg]:px-4 w-full sm:w-auto h-14 px-8 text-lg bg-white text-black hover:bg-gray-200 rounded-full\" href=\"#packages\">View Service Packages <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right ml-2 w-5 h-5\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a><a data-slot=\"button\" data-variant=\"outline\" data-size=\"lg\" class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-all disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg:not([class*=&#x27;size-&#x27;])]:size-4 shrink-0 [&amp;_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive border bg-background shadow-xs hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 has-[&gt;svg]:px-4 w-full sm:w-auto h-14 px-8 text-lg rounded-full border-white/20 hover:bg-white/10\" href=\"#portfolio\">See Past Work</a></div></div><div class=\"absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none\"></div></section><section class=\"py-24 bg-zinc-950 text-white relative flex flex-col items-center\"><div class=\"container mx-auto px-4 relative z-10\"><div class=\"text-center max-w-3xl mx-auto mb-16\"><h2 class=\"text-4xl md:text-5xl font-bold mb-6\" style=\"opacity:0;transform:translateY(20px)\">Why choose <span class=\"text-blue-400\">1DayWeb?</span></h2><p class=\"text-xl text-zinc-400\" style=\"opacity:0;transform:translateY(20px)\">Traditional agencies take too long and cost too much. DIY builders are frustrating and look generic. We offer the perfect middle ground.</p></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto\"><div style=\"opacity:0;transform:translateY(20px)\"><div data-slot=\"card\" class=\"text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm bg-zinc-900/50 border-zinc-800 hover:border-zinc-700 transition-colors h-full backdrop-blur-sm\"><div data-slot=\"card-header\" class=\"@container/card-header grid auto-rows-min grid-rows-[auto_auto] items-start gap-2 px-6 has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6\"><div class=\"w-14 h-14 rounded-2xl bg-zinc-800 flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock w-8 h-8 text-blue-400\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6l4 2\"></path></svg></div><div data-slot=\"card-title\" class=\"font-semibold text-2xl text-white\">No Months of Waiting</div></div><div data-slot=\"card-content\" class=\"px-6\"><p class=\"text-zinc-400 leading-relaxed text-lg\">We skip the endless meetings and deliver in days, not months. The base package is ready in just 24 hours.</p></div></div></div><div style=\"opacity:0;transform:translateY(20px)\"><div data-slot=\"card\" class=\"text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm bg-zinc-900/50 border-zinc-800 hover:border-zinc-700 transition-colors h-full backdrop-blur-sm\"><div data-slot=\"card-header\" class=\"@container/card-header grid auto-rows-min grid-rows-[auto_auto] items-start gap-2 px-6 has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6\"><div class=\"w-14 h-14 rounded-2xl bg-zinc-800 flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check w-8 h-8 text-green-400\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg></div><div data-slot=\"card-title\" class=\"font-semibold text-2xl text-white\">Transparent Pricing</div></div><div data-slot=\"card-content\" class=\"px-6\"><p class=\"text-zinc-400 leading-relaxed text-lg\">No hidden fees, no unexpected retainers, no feature creep. You pay a single flat rate upfront.</p></div></div></div><div style=\"opacity:0;transform:translateY(20px)\"><div data-slot=\"card\" class=\"text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm bg-zinc-900/50 border-zinc-800 hover:border-zinc-700 transition-colors h-full backdrop-blur-sm\"><div data-slot=\"card-header\" class=\"@container/card-header grid auto-rows-min grid-rows-[auto_auto] items-start gap-2 px-6 has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6\"><div class=\"w-14 h-14 rounded-2xl bg-zinc-800 flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sparkles w-8 h-8 text-purple-400\" aria-hidden=\"true\"><path d=\"M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z\"></path><path d=\"M20 2v4\"></path><path d=\"M22 4h-4\"></path><circle cx=\"4\" cy=\"20\" r=\"2\"></circle></svg></div><div data-slot=\"card-title\" class=\"font-semibold text-2xl text-white\">Premium Quality</div></div><div data-slot=\"card-content\" class=\"px-6\"><p class=\"text-zinc-400 leading-relaxed text-lg\">Fast doesn&#x27;t mean cheap. We build high-converting, bespoke designs that make your business look like a million bucks.</p></div></div></div></div></div></section><section id=\"how-it-works\" class=\"py-24 bg-black text-white relative\"><div class=\"container mx-auto px-4 max-w-6xl\"><div class=\"text-center mb-20\" style=\"opacity:0;transform:translateY(20px)\"><h2 class=\"text-4xl md:text-5xl font-bold mb-6\">How it <span class=\"text-purple-400\">works</span></h2><p class=\"text-xl text-zinc-400 max-w-2xl mx-auto\">A streamlined process designed to get you online as fast as possible without sacrificing quality.</p></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-12 relative\"><div class=\"hidden md:block absolute top-[4.5rem] left-[15%] right-[15%] h-[2px] bg-gradient-to-r from-zinc-800 via-zinc-600 to-zinc-800 z-0\"></div><div class=\"relative z-10 flex flex-col items-center text-center\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"w-36 h-36 rounded-full bg-zinc-950 border-4 border-zinc-800 flex items-center justify-center text-5xl font-black text-white mb-8 shadow-2xl relative\"><div class=\"absolute inset-0 rounded-full bg-purple-500/10 blur-xl\"></div><span class=\"relative z-10 bg-clip-text text-transparent bg-gradient-to-b from-white to-zinc-500\">01</span></div><h3 class=\"text-2xl font-bold mb-4\">Choose a Package</h3><p class=\"text-zinc-400 text-lg\">Select the timeline that fits your needs: 1-Day, 3-Day, or 5-Day custom build.</p></div><div class=\"relative z-10 flex flex-col items-center text-center\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"w-36 h-36 rounded-full bg-zinc-950 border-4 border-zinc-800 flex items-center justify-center text-5xl font-black text-white mb-8 shadow-2xl relative\"><div class=\"absolute inset-0 rounded-full bg-purple-500/10 blur-xl\"></div><span class=\"relative z-10 bg-clip-text text-transparent bg-gradient-to-b from-white to-zinc-500\">02</span></div><h3 class=\"text-2xl font-bold mb-4\">Tell Us What You Need</h3><p class=\"text-zinc-400 text-lg\">Fill out a quick 5-minute intake form about your brand, goals, and design preferences.</p></div><div class=\"relative z-10 flex flex-col items-center text-center\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"w-36 h-36 rounded-full bg-zinc-950 border-4 border-zinc-800 flex items-center justify-center text-5xl font-black text-white mb-8 shadow-2xl relative\"><div class=\"absolute inset-0 rounded-full bg-purple-500/10 blur-xl\"></div><span class=\"relative z-10 bg-clip-text text-transparent bg-gradient-to-b from-white to-zinc-500\">03</span></div><h3 class=\"text-2xl font-bold mb-4\">We Build It</h3><p class=\"text-zinc-400 text-lg\">Sit back and relax. We&#x27;ll design, develop, and deliver your premium website before the deadline.</p></div></div></div></section><section id=\"portfolio\" class=\"py-24 bg-black text-white relative\"><div class=\"container mx-auto px-4 max-w-7xl\"><div class=\"flex flex-col md:flex-row items-end justify-between mb-16 gap-6\"><div class=\" max-w-2xl\" style=\"opacity:0;transform:translateX(-20px)\"><h2 class=\"text-4xl md:text-5xl font-bold mb-4\">Recent <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-500\">Work</span></h2><p class=\"text-xl text-zinc-400\">Take a look at what we&#x27;ve built recently. High quality, delivered at record speed.</p></div></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\"><div class=\"group relative rounded-2xl overflow-hidden bg-zinc-900 aspect-video block\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"absolute inset-0 bg-zinc-800 animate-pulse\"></div> <div class=\"absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105\" style=\"background-image:url(https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&amp;w=2070&amp;auto=format&amp;fit=crop)\" title=\"SaaS Dashboard\"></div><div class=\"absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300\"></div><div class=\"absolute bottom-0 left-0 right-0 p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-300\"><span class=\"text-sm font-semibold text-purple-400 mb-2 block tracking-wider uppercase\">Web App • 5-Day Custom</span><h3 class=\"text-2xl font-bold text-white\">SaaS Dashboard</h3></div></div><div class=\"group relative rounded-2xl overflow-hidden bg-zinc-900 aspect-video block\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"absolute inset-0 bg-zinc-800 animate-pulse\"></div> <div class=\"absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105\" style=\"background-image:url(https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&amp;w=2015&amp;auto=format&amp;fit=crop)\" title=\"Boutique E-commerce\"></div><div class=\"absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300\"></div><div class=\"absolute bottom-0 left-0 right-0 p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration